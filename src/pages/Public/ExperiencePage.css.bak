/* ExperiencePage.css */

.experience-page {
    background-color: #fff;
    color: #4a4a4a;
    /* Dark gray for text */
}

/* Hero Section */
.experience-hero {
    height: 90vh;
    width: 100%;
    background-image: url('/beautiful-view-of-the-caribbean-beach-during-summe-2026-01-07-23-50-25-utc.jpg');
    /* Verify asset name */
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
}

.experience-hero-overlay {
    background: rgba(0, 0, 0, 0.3);
    /* Slight dark overlay for text readability */
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
}

.experience-hero h1 {
    color: #fff;
    font-size: 3.5rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-align: center;
    padding: 0 20px;
}

/* Intro Section */
.experience-intro {
    padding: 100px 20px;
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
}

.intro-text h2 {
    font-size: 2.5rem;
    color: var(--color-primary);
    /* Deep Blue from palette */
    margin-bottom: 40px;
    font-weight: 500;
}

.intro-text p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #555;
    margin-bottom: 25px;
}

.intro-highlight {
    font-style: italic;
    color: var(--color-primary) !important;
    font-weight: 500;
    margin-top: 40px;
}

/* Split Sections (Zig-Zag) */
.content-split-section {
    padding: 80px 0;
    width: 100%;
    overflow: hidden;
}

.split-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 60px;
    max-width: 1200px;
    /* Constrain width for large screens */
    margin: 0 auto;
    padding: 0 20px;
}

/* Reverse layout for alternate sections */
.split-container.reverse-layout {
    flex-direction: row-reverse;
    /* Just visually swap image and text */
}

.split-content {
    flex: 1;
    max-width: 500px;
}

.split-content h3 {
    font-size: 2rem;
    color: var(--color-primary);
    margin-bottom: 25px;
    position: relative;
    display: inline-block;
}

/* Removed Gold Underline */
.split-content h3::after {
    display: none;
}

.split-content.text-right {
    text-align: right;
}

.split-content p {
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 30px;
}

.explore-link {
    display: inline-block;
    color: var(--color-primary);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 1px;
    text-decoration: none;
    padding-bottom: 4px;
    transition: all 0.3s ease;
}

.explore-link:hover {
    opacity: 0.8;
}

.split-image {
    flex: 1;
    height: 500px;
    /* Fixed height for consistency */
    overflow: hidden;
    position: relative;
}

.split-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
}

.split-image:hover img {
    transform: scale(1.03);
}

/* Integrated Gallery specific overrides */
.integrated-gallery.gallery-split-layout {
    padding-top: 0;
    margin-top: var(--spacing-xl);
    padding-bottom: var(--spacing-xl);
}

@media (max-width: 900px) {
    .integrated-gallery.gallery-split-layout {
        margin-top: var(--spacing-lg);
        padding-bottom: var(--spacing-lg);
        gap: 60px;
        /* Better separation between masonry and sidebar tabs */
    }
}

/* Responsive Design */

@media (max-width: 900px) {
    .experience-hero {
        height: 70vh;
    }

    .experience-intro {
        padding: 60px 20px;
    }

    .intro-text h2 {
        font-size: 1.75rem;
        margin-bottom: 25px;
    }

    .intro-text p {
        font-size: 1rem;
        line-height: 1.7;
    }

    .content-split-section {
        padding: 40px 0;
    }

    .split-container,
    .split-container.reverse-layout {
        flex-direction: column-reverse;
        /* Image on top, text on bottom */
        gap: 30px;
    }

    /* Ensure image is first on mobile for visual flow */
    .content-split-section.reverse-mobile .split-container {
        flex-direction: column-reverse;
    }

    .split-content {
        max-width: 100%;
        text-align: left !important;
        /* Keep left alignment for premium feel */
    }

    .split-content h3 {
        font-size: 1.5rem;
        margin-bottom: 15px;
    }

    .split-content p {
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 20px;
    }

    .split-image {
        height: 300px;
        width: 100%;
        /* Full width edge-to-edge on small mobile looks premium */
        margin-left: -20px;
        margin-right: -20px;
        width: calc(100% + 40px);
    }
}

@media (max-width: 480px) {
    .experience-hero {
        height: 60vh;
    }

    .experience-intro {
        padding: 40px 20px;
    }

    .intro-text h2 {
        font-size: 1.5rem;
    }

    .split-image {
        height: 250px;
    }
}

.intro-text .subhead-text {
    font-family: var(--font-subhead);
    font-size: 1.2rem;
    color: #888;
    margin-top: -20px;
    margin-bottom: 30px;
    font-weight: 300;
    text-transform: none;
}

.intro-text .justified-text {
    text-align: justify;
    text-justify: inter-word;
    margin-bottom: 25px;
}

/* Settings Header */
.settings-header {
    padding: 60px 0 20px;
}

.settings-header .section-title {
    margin-bottom: 10px;
}

.settings-header .section-subtitle {
    font-family: var(--font-subhead);
    font-size: 1.2rem;
    color: #666;
    font-weight: 300;
}

/* Location Section */
.experience-location-section {
    padding: 100px 0;
    background-color: #f9f9f9;
}

.location-header {
    margin-bottom: 50px;
}

.location-icon {
    color: var(--color-accent);
    margin-bottom: 15px;
}

.location-header h2 {
    font-size: 2.5rem;
    color: var(--color-primary);
    margin-bottom: 10px;
}

.location-header p {
    font-family: var(--font-subhead);
    font-size: 1.2rem;
    color: #666;
}

.location-map-wrapper {
    height: 500px;
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
}

@media (max-width: 768px) {
    .experience-location-section {
        padding: 60px 0;
    }

    .location-header h2 {
        font-size: 2rem;
    }

    .location-map-wrapper {
        height: 350px;
    }
}
}